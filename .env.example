# =============================================================================
# .env.example — Template d'environnement pour [NOM_DU_PROJET]
# =============================================================================
# Copier ce fichier en .env.local et remplir les valeurs.
# .env.local est gitignoré — ne JAMAIS commit les vraies valeurs.
# =============================================================================


# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
# Clé fournie par les organisateurs du hackathon.
# Utilisée par le service Python (FastAPI) uniquement.
OPENAI_API_KEY=sk-...


# -----------------------------------------------------------------------------
# GitHub App
# -----------------------------------------------------------------------------
# Récupérables sur la page de votre GitHub App :
# Settings de l'org → Developer settings → GitHub Apps → [Votre App]

# App ID (entier, affiché en haut de la page de l'app)
GITHUB_APP_ID=

# Private key (.pem). Format multi-ligne avec \n littéraux entre guillemets.
# Exemple : "-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY=""

# Webhook secret (string random forte).
# Générer avec : openssl rand -hex 32
GITHUB_APP_WEBHOOK_SECRET=

# Client ID (affiché sur la page de l'app)
GITHUB_APP_CLIENT_ID=

# Client secret (à générer sur la page de l'app, "Generate a new client secret")
GITHUB_APP_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Base de données (SQLite)
# -----------------------------------------------------------------------------
# Fichier local, créé automatiquement par Prisma.
DATABASE_URL="file:./dev.db"


# -----------------------------------------------------------------------------
# Services
# -----------------------------------------------------------------------------
# URL du service Python (FastAPI). En local : http://localhost:8000
AI_SERVICE_URL=http://localhost:8000

# URL publique de l'app Next.js (utilisée pour les liens dans les commentaires PR).
# En dev avec ngrok Static Domain : https://your-team.ngrok-free.app
NEXT_PUBLIC_APP_URL=https://your-team.ngrok-free.app


# -----------------------------------------------------------------------------
# Configuration des seuils (optionnel, valeurs par défaut sinon)
# -----------------------------------------------------------------------------
# Score minimum (0-100) pour valider la compréhension et débloquer le merge
UNDERSTANDING_THRESHOLD=70

# Nombre de lignes minimum dans le diff pour déclencher une analyse
DIFF_LINES_THRESHOLD=50

# Modèle à utiliser en mode dev/debug (override les MODELS du code)
# Laisser vide pour utiliser les modèles par défaut définis dans ai/llm.py
DEV_MODEL_OVERRIDE=
